# Copy to .env and fill in real values. NEVER commit .env.

# ─── App ───────────────────────────────────────────────────────────
HTTP_ADDR=:8080
PUBLIC_BASE_URL=http://localhost:8080
HTTP_PUBLISH_PORT=8080

# Database: sqlite (default, local binary) or mysql (docker-compose)
DB_DRIVER=sqlite

# SQLite (when DB_DRIVER=sqlite)
DATABASE_PATH=./data/m365backup.db

# MySQL (when DB_DRIVER=mysql) — used by docker-compose and bare-metal
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=m365backup
MYSQL_PASSWORD=
MYSQL_DATABASE=m365backup
MYSQL_ROOT_PASSWORD=
# Optional full DSN instead of discrete vars:
# MYSQL_DSN=m365backup:password@tcp(mysql:3306)/m365backup?parseTime=true&loc=UTC

# Snapshot + staging paths (also used as docker bind-mount sources)
KOPIA_ROOT=./data/kopia
STAGING_ROOT=./data/staging

# Host paths for docker compose volume mounts (absolute or relative)
DATA_KOPIA_PATH=./data/kopia
DATA_STAGING_PATH=./data/staging
MYSQL_DATA_PATH=./data/mysql

# 32-byte master key, base64-encoded. Generate with:
#   openssl rand -base64 32
MASTER_KEY=

# Admin UI password (min 8 characters; 12+ recommended)
ADMIN_PASSWORD=

MAX_CONCURRENT_JOBS=2
# Parallel Exchange mailboxes within one job (Graph calls). First sync is still heavy; later syncs use delta.
EXCHANGE_WORKERS=6

# Optional default SMTP (can also be configured in the UI)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_FROM=m365backup@example.com
# SMTP_TO=ops@example.com
